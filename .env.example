# ElevenLabs — Text-to-Speech (AI host voice) and Speech-to-Text (podcast segmenter)
# Get your key at https://elevenlabs.io
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=
VITE_ELEVENLABS_VOICE_ID_DE=    # optional: German voice (e.g. 87AwpS6yC86wa2WglbsK)

# Anthropic — Claude AI for podcast commentary
# Get your key at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=

# PodcastIndex — podcast search and trending
# Get free credentials at https://podcastindex.org/developer
VITE_PODCASTINDEX_API_KEY=
VITE_PODCASTINDEX_API_SECRET=
